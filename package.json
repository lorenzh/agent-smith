{
	"name": "agent-smith",
	"private": true,
	"type": "module",
	"description": "An MCP gateway: one MCP server that aggregates many downstream MCP servers behind a single endpoint.",
	"license": "MIT",
	"author": "Lorenz Hilpert",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lorenzh/agent-smith.git"
	},
	"homepage": "https://github.com/lorenzh/agent-smith#readme",
	"bugs": {
		"url": "https://github.com/lorenzh/agent-smith/issues"
	},
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@types/bun": "latest",
		"lefthook": "^2.1.9"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"scripts": {
		"dev": "bun run --hot apps/server/src/index.ts",
		"lint": "biome check .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"prepare": "lefthook install"
	}
}
